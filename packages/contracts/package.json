{
  "name": "@vpp/contracts",
  "version": "1.0.0",
  "private": true,
  "description": "VPP SurveyPoints smart contract for Base L2",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/hsbi-business-psychology/vpp-blockchain.git",
    "directory": "packages/contracts"
  },
  "scripts": {
    "compile": "hardhat compile",
    "test": "hardhat test",
    "coverage": "hardhat coverage",
    "deploy:local": "hardhat run scripts/deploy.ts --network localhost",
    "deploy:dev": "hardhat run scripts/deploy-local.ts --network localhost",
    "deploy:dev:v2": "hardhat run scripts/deploy-v2-local.ts --network localhost",
    "node": "hardhat node",
    "deploy:sepolia": "hardhat run scripts/deploy.ts --network baseSepolia",
    "deploy:mainnet": "hardhat run scripts/deploy.ts --network baseMainnet",
    "deploy:v2:sepolia": "hardhat run scripts/deploy-v2.ts --network baseSepolia",
    "deploy:v2:mainnet": "hardhat run scripts/deploy-v2.ts --network baseMainnet",
    "upgrade:v2:sepolia": "hardhat run scripts/upgrade-v2.ts --network baseSepolia",
    "upgrade:v2:mainnet": "hardhat run scripts/upgrade-v2.ts --network baseMainnet",
    "clean": "hardhat clean && rm -rf coverage coverage.json"
  },
  "devDependencies": {
    "@nomicfoundation/hardhat-toolbox": "^5.0.0",
    "@openzeppelin/contracts": "^5.1.0",
    "@openzeppelin/contracts-upgradeable": "^5.6.1",
    "@openzeppelin/hardhat-upgrades": "^3.9.1",
    "dotenv": "^16.4.0",
    "hardhat": "^2.22.0"
  }
}
