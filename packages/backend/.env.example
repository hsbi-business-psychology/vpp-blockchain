# Server
PORT=3000

# Blockchain
RPC_URL=https://sepolia.base.org
CONTRACT_ADDRESS=0x_YOUR_DEPLOYED_CONTRACT_ADDRESS
MINTER_PRIVATE_KEY=0x_YOUR_BACKEND_WALLET_PRIVATE_KEY

# Admin access is now managed on-chain via ADMIN_ROLE in the smart contract.
# No ADMIN_WALLETS env var needed — the backend queries the contract directly.

# Block number at which the contract was deployed (speeds up event queries).
# Set this after deploying your contract. Leave at 0 for local development.
CONTRACT_DEPLOY_BLOCK=0

# Block explorer base URL (used for transaction links in responses)
EXPLORER_BASE_URL=https://sepolia.basescan.org

# Frontend URL (for CORS and template redirect URLs)
FRONTEND_URL=http://localhost:5173

# Rate limiting
CLAIM_RATE_LIMIT_WINDOW_MS=60000
CLAIM_RATE_LIMIT_MAX=5
API_RATE_LIMIT_WINDOW_MS=60000
API_RATE_LIMIT_MAX=100

# Log level: 'fatal', 'error', 'warn', 'info' (default), 'debug', 'trace'
# LOG_LEVEL=info

# Trust proxy: 'false' (default), 'true', '1', '2', 'loopback', IP/CIDR
# Set to 'true' or '1' when behind Nginx, Plesk, or Docker
# TRUST_PROXY=false

# Rate limit store: 'memory' (default, single-instance) or 'redis' (multi-instance)
# RATE_LIMIT_STORE=memory
# REDIS_URL=redis://localhost:6379
