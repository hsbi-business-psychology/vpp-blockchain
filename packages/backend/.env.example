# Server
PORT=3000

# Blockchain
RPC_URL=https://sepolia.base.org
CONTRACT_ADDRESS=0x_YOUR_DEPLOYED_CONTRACT_ADDRESS
MINTER_PRIVATE_KEY=0x_YOUR_BACKEND_WALLET_PRIVATE_KEY

# Admin access is now managed on-chain via ADMIN_ROLE in the smart contract.
# No ADMIN_WALLETS env var needed — the backend queries the contract directly.

# Block number at which the contract was deployed (speeds up event queries).
# Set this after deploying your contract. Leave at 0 for local development.
CONTRACT_DEPLOY_BLOCK=0

# Block explorer base URL (used for transaction links in responses)
EXPLORER_BASE_URL=https://sepolia.basescan.org

# Frontend URL (for CORS and template redirect URLs)
FRONTEND_URL=http://localhost:5173

# Rate limiting (defaults sized for a 100-student class behind one
# shared NAT IP — HSBI eduroam, lecture hall WiFi). Real abuse defence
# is the per-survey HMAC nonce + on-chain _claimed guard, not these
# IP-based limits. See src/config.ts JSDoc for the sizing math.
CLAIM_RATE_LIMIT_WINDOW_MS=60000
CLAIM_RATE_LIMIT_MAX=500
API_RATE_LIMIT_WINDOW_MS=60000
API_RATE_LIMIT_MAX=2000

# Log level: 'fatal', 'error', 'warn', 'info' (default), 'debug', 'trace'
# LOG_LEVEL=info

# Trust proxy: 'false' (default), 'true', '1', '2', 'loopback', IP/CIDR
# Set to 'true' or '1' when behind Nginx, Plesk, or Docker
# TRUST_PROXY=false

# Rate limit store: 'memory' (default, single-instance) or 'redis' (multi-instance)
# RATE_LIMIT_STORE=memory
# REDIS_URL=redis://localhost:6379

# Chain ID validation (set to fail fast on RPC misconfiguration)
# EXPECTED_CHAIN_ID=84532       # Base Sepolia (use 8453 for Base Mainnet)

# Timing configuration
# MAX_MESSAGE_AGE_MS=60000     # Max age of signed messages (60 s default; raise carefully — increases replay window)
# SYNC_INTERVAL_MS=60000       # Event store sync interval (60s default)
# CACHE_TTL_MS=30000           # Survey cache TTL (30s default)
# CHUNK_SIZE=9000              # RPC query chunk size in blocks (9000 default)

# Minter wallet balance management (audit F2.4) — defaults sized for Base mainnet
# MIN_BALANCE_ETH=0.002             # Hard floor; backend returns 503 below this. ~6 Tx at our 2-gwei worst-case cap, ~133 Tx at typical Base gas. Bump for L1/OP/Arb where gas is more expensive.
# BALANCE_MONITOR_INTERVAL_MS=3600000  # 1h. Set to 0 to disable. Emits MINTER_BALANCE_LOW warn line at <5× floor (= 0.01 ETH default) for the Plesk cron grep.

# Gas fee hard caps applied to every state-changing tx (audit F2.3)
# Base baseFee is typically 0.01-0.1 gwei; spikes (NFT waves, sequencer
# backlog) have hit 5-50 gwei in 2024-2025. Without a cap, ethers v6
# would happily burn 16 000x the normal fee. With these caps, a Tx
# during a spike hangs in the mempool until baseFee drops back below
# the ceiling — students see a delay, not a silent wallet drain.
# MAX_FEE_PER_GAS_GWEI=2
# MAX_PRIORITY_FEE_PER_GAS_GWEI=0.5
