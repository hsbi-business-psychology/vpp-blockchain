# ╔══════════════════════════════════════════════════════════════╗
# ║  VPP Blockchain — Production Environment Variables         ║
# ║                                                            ║
# ║  Copy this file to .env on the Plesk server (httpdocs/)    ║
# ║  OR set these as "Custom Environment Variables" in the     ║
# ║  Plesk Node.js panel.                                      ║
# ╚══════════════════════════════════════════════════════════════╝

# Server
PORT=3000
NODE_ENV=production

# Blockchain (Base Mainnet)
RPC_URL=https://mainnet.base.org
CONTRACT_ADDRESS=0x_YOUR_DEPLOYED_CONTRACT_ADDRESS
MINTER_PRIVATE_KEY=0x_YOUR_BACKEND_WALLET_PRIVATE_KEY

# Block number at which the contract was deployed (speeds up event queries)
CONTRACT_DEPLOY_BLOCK=0

# Block explorer base URL
EXPLORER_BASE_URL=https://basescan.org

# Frontend URL (same domain in production — used for CORS and template URLs)
FRONTEND_URL=https://vpstunden.hsbi.de
