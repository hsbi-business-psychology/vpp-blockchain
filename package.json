{
  "name": "vpp-blockchain",
  "version": "0.0.0",
  "private": true,
  "description": "Verifiable Participant Points — a blockchain-based system for awarding tamper-proof survey participation points",
  "author": "HSBI BInEx",
  "license": "MIT",
  "engines": {
    "node": ">=20.0.0",
    "pnpm": ">=9.0.0"
  },
  "packageManager": "pnpm@9.15.4",
  "scripts": {
    "build": "pnpm -r run build",
    "test": "pnpm -r run test",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "clean": "pnpm -r run clean",
    "dev": "bash scripts/dev.sh",
    "dev:node": "pnpm --filter @vpp/contracts node",
    "dev:deploy": "pnpm --filter @vpp/contracts deploy:dev",
    "dev:backend": "cp -n packages/backend/.env.development packages/backend/.env 2>/dev/null; pnpm --filter @vpp/backend dev",
    "dev:frontend": "pnpm --filter @vpp/frontend dev"
  },
  "devDependencies": {
    "concurrently": "^9.2.1"
  }
}
