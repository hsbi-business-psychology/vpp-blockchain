# Auto-detect text files and normalise line endings to LF
* text=auto eol=lf

# Explicitly declare text files
*.ts       text diff=typescript
*.tsx      text diff=typescript
*.js       text diff=javascript
*.jsx      text diff=javascript
*.mjs      text diff=javascript
*.json     text
*.md       text diff=markdown
*.css      text
*.html     text diff=html
*.yml      text
*.yaml     text
*.toml     text
*.sol      text
*.sh       text eol=lf
*.env*     text

# Binary files
*.png      binary
*.jpg      binary
*.jpeg     binary
*.gif      binary
*.ico      binary
*.webp     binary
*.svg      text
*.woff     binary
*.woff2    binary

# Lock files — keep generated, show diffs only in stat
pnpm-lock.yaml  -diff linguist-generated=true

# Solidity ABI artifacts — generated
packages/contracts/artifacts/** linguist-generated=true
packages/contracts/typechain-types/** linguist-generated=true
